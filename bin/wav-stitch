#!/usr/bin/env bash
set -euo pipefail

usage() {
    echo "Usage: $0 <file1.wav> [file2.wav ...] --out <output.wav>" >&2
    exit 1
}

# Parse --out from args
out=""
inputs=()
while [ $# -gt 0 ]; do
    case "$1" in
        --out)
            shift
            [ $# -eq 0 ] && usage
            out="$1"
            ;;
        *)
            inputs+=("$1")
            ;;
    esac
    shift
done

[ -z "$out" ] && usage
[ ${#inputs[@]} -eq 0 ] && usage

# Build ffmpeg concat file list
concat_file=$(mktemp)
trap 'rm -f "$concat_file"' EXIT

for f in "${inputs[@]}"; do
    echo "file '$(realpath "$f")'" >> "$concat_file"
done

ffmpeg -f concat -safe 0 -i "$concat_file" -c copy "$out"
